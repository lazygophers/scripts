#!/usr/bin/env python3
"""switch_branch 薄壳入口 — 批量切换分支。"""
from __future__ import annotations

import argparse
import pathlib
import sys

sys.path.insert(0, str(pathlib.Path(__file__).resolve().parent.parent))
from lib.batch_git import switch_branch_all
from lib.notify import consume_debug, consume_no_say
from lib.ui import timed


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(
        description="批量切换分支：扫描 Git 仓库，切换到指定分支",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("branch", help="目标分支名")
    args = parser.parse_args(argv[1:])
    return switch_branch_all(args.branch)


if __name__ == "__main__":
    sys.argv = consume_debug(consume_no_say(sys.argv))
    raise SystemExit(timed(main, label="switch_branch")(sys.argv))
