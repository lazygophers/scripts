#!/usr/bin/env python3
"""sync_master 薄壳入口 — 批量同步 master 到 origin/master。"""
import argparse
import pathlib
import sys

sys.path.insert(0, str(pathlib.Path(__file__).resolve().parent.parent))
from lib.batch_git import sync_master_all


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(
        description="批量同步 master：将本地 master 硬对齐到 origin/master",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("--force", action="store_true",
                        help="强制：即便本地领先也硬 reset 到 origin/master")
    args = parser.parse_args(argv[1:])
    return sync_master_all(force=args.force)


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
