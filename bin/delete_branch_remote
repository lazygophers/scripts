#!/usr/bin/env python3
"""delete_branch_remote 薄壳入口 — 删除远端分支。

单仓（当前在 git 仓库）→ 删当前仓库远端分支；非 git 目录 → 批量扫描所有 Git 仓库。
单仓路径复用 lib 工厂闭包，确保 skip/prune 规则与批量一致（spec batch-git.md）。
"""
import argparse
import os
import pathlib
import sys

sys.path.insert(0, str(pathlib.Path(__file__).resolve().parent.parent))
from lib.batch_git import _delete_branch_remote_one_factory
from lib.ui import reporter, timed

_STATUS_EXIT = {"ok": 0, "skip": 0, "fail": 1}


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(
        description="删除远端分支：当前在 git 仓库删单仓，非 git 目录批量扫描 Git 仓库",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("branch", help="要删除的分支名")
    parser.add_argument("--remote", default="origin", help="远端名（默认 origin）")
    parser.add_argument("-y", "--yes", action="store_true", help="批量模式跳过确认")
    args = parser.parse_args(argv[1:])

    in_git = (pathlib.Path.cwd() / ".git").exists()
    if in_git:
        r = reporter(stderr=True)
        op = _delete_branch_remote_one_factory(args.branch, remote=args.remote)
        status, detail = op(pathlib.Path.cwd(), r, pathlib.Path.cwd())
        if detail:
            (r.ok if status == "ok" else r.warn if status == "skip" else r.err)(detail)
        return _STATUS_EXIT.get(status, 1)

    from lib.batch_git import delete_branch_remote_all
    if args.yes:
        os.environ["BATCH_NO_CONFIRM"] = "1"
    return delete_branch_remote_all(args.branch, remote=args.remote)


if __name__ == "__main__":
    raise SystemExit(timed(main, label="delete_branch_remote")(sys.argv))
