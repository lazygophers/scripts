#!/usr/bin/env python3
"""delete_branch 薄壳入口 — 删除本地分支。

单仓（当前在 git 仓库）→ 删当前仓库分支；非 git 目录 → 批量扫描所有 Git 仓库。
单仓路径复用 lib 工厂闭包，确保 skip/prune 规则与批量一致（spec batch-git.md）。
"""
import argparse
import os
import pathlib
import sys

sys.path.insert(0, str(pathlib.Path(__file__).resolve().parent.parent))
from lib.batch_git import _delete_branch_one_factory
from lib.ui import reporter

# 单仓 / 批量统一的状态 → 退出码映射（skip 非失败，exit 0）
_STATUS_EXIT = {"ok": 0, "skip": 0, "fail": 1}


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(
        description="删除本地分支：当前在 git 仓库删单仓，非 git 目录批量扫描 Git 仓库",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("branch", help="要删除的分支名")
    parser.add_argument("--force", action="store_true",
                        help="强删（-D）：即便未合并也删")
    parser.add_argument("-y", "--yes", action="store_true",
                        help="批量模式跳过确认")
    args = parser.parse_args(argv[1:])

    in_git = (pathlib.Path.cwd() / ".git").exists()
    if in_git:
        r = reporter(stderr=True)
        op = _delete_branch_one_factory(args.branch, args.force)
        status, detail = op(pathlib.Path.cwd(), r, pathlib.Path.cwd())
        if detail:
            (r.ok if status == "ok" else r.warn if status == "skip" else r.err)(detail)
        return _STATUS_EXIT.get(status, 1)

    from lib.batch_git import delete_branch_all
    if args.yes:
        os.environ["BATCH_NO_CONFIRM"] = "1"
    return delete_branch_all(args.branch, force=args.force)


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
