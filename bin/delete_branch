#!/usr/bin/env python3
"""delete_branch 薄壳入口 — 删除本地分支。

单仓（当前在 git 仓库）→ 删当前仓库分支；非 git 目录 → 批量扫描所有 Git 仓库。
"""
import argparse
import os
import pathlib
import sys

sys.path.insert(0, str(pathlib.Path(__file__).resolve().parent.parent))
from lib.exec import run
from lib.ui import reporter


def _delete_local_single(target: str, force: bool) -> int:
    """单仓删除本地分支。"""
    r = reporter(stderr=True)
    cur = run(["git", "branch", "--show-current"], check=False, capture_output=True)
    if (cur.stdout or "").strip() == target:
        r.warn(f"当前分支即 {target}，先 switch 到其他分支再删")
        return 1

    exists = run(["git", "show-ref", "--verify", "--quiet", f"refs/heads/{target}"],
                 check=False, capture_output=True)
    if exists.returncode != 0:
        r.warn(f"无本地分支 {target}")
        return 1

    flag = "-D" if force else "-d"
    r.step(f"git branch {flag} {target}")
    p = run(["git", "branch", flag, target], check=False, capture_output=True)
    if p.returncode != 0:
        err = (p.stderr or "") + (p.stdout or "")
        if not force and "not fully merged" in err:
            r.warn(f"{target} 未合并（--force 强删）")
            return 1
        r.err(f"删除失败: {err.strip()}")
        return 1
    r.ok(f"已删本地 {target}")
    return 0


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(
        description="删除本地分支：当前在 git 仓库删单仓，非 git 目录批量扫描 Git 仓库",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("branch", help="要删除的分支名")
    parser.add_argument("--force", action="store_true",
                        help="强删（-D）：即便未合并也删")
    parser.add_argument("-y", "--yes", action="store_true",
                        help="批量模式跳过确认")
    args = parser.parse_args(argv[1:])

    in_git = (pathlib.Path.cwd() / ".git").exists()
    if in_git:
        return _delete_local_single(args.branch, args.force)

    from lib.batch_git import delete_branch_all
    if args.yes:
        os.environ["BATCH_NO_CONFIRM"] = "1"
    return delete_branch_all(args.branch, force=args.force)


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
