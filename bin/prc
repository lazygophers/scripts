#!/usr/bin/env python3
"""prc 薄壳入口 — 自动创建 PR/MR（调 claude 生成 title/body）。"""
import argparse
import pathlib
import sys

sys.path.insert(0, str(pathlib.Path(__file__).resolve().parent.parent))
from lib.prc_wf import run_prc


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(
        description="自动创建 PR/MR",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="示例:\n  prc main\n  prc --base develop\n  prc --dry-run",
    )
    parser.add_argument("--dry-run", action="store_true", help="预览模式，不创建")
    parser.add_argument("--no-draft", action="store_true", help="创建为正式 PR/MR（默认 draft）")
    parser.add_argument("--base", help="目标分支（默认: 检测远端默认分支）")
    parser.add_argument("--settings", help="指定 claude settings 文件")
    parser.add_argument("--reviews", help="指定 reviewers")
    parser.add_argument("--labels", help="指定 labels")
    parser.add_argument("--assignee", help="指定 assignee")
    parser.add_argument("base_pos", nargs="?", default=None, help="目标分支（位置参数，与 --base 等价）")
    args = parser.parse_args(argv[1:])

    base = args.base or args.base_pos
    return run_prc(
        base,
        dry_run=args.dry_run,
        draft=not args.no_draft,
        reviews=args.reviews,
        labels=args.labels,
        assignee=args.assignee,
        settings_file=args.settings,
    )


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
