#!/usr/bin/env python3
"""push_branch 薄壳入口 — 批量推送当前分支到远端同名分支。

与 sync_branch 方向相反：本地 → 远端。先 pull --ff-only 同步远端到本地，再 push。
"""
from __future__ import annotations

import argparse
import pathlib
import sys

sys.path.insert(0, str(pathlib.Path(__file__).resolve().parent.parent))
from lib.batch_git import push_branch_all
from lib.ui import timed


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(
        description="批量推送分支：默认推送各仓库当前分支，传 <branch> 推送指定分支（先 pull --ff-only 再 push）",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("branch", nargs="?", default=None,
                        help="目标分支名（省略则推送各仓库当前分支）")
    parser.add_argument("--force", action="store_true",
                        help="强推：使用 --force-with-lease 覆盖远端")
    args = parser.parse_args(argv[1:])
    return push_branch_all(args.branch, force=args.force)


if __name__ == "__main__":
    raise SystemExit(timed(main, label="push_branch")(sys.argv))
