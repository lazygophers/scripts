#!/usr/bin/env python3
"""commit 薄壳入口 — 自动提交变更（调 claude 生成 message）。"""
import argparse
import pathlib
import sys

sys.path.insert(0, str(pathlib.Path(__file__).resolve().parent.parent))
from lib.commit_wf import run_commit


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(
        description="自动提交变更",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="示例:\n  commit \"fix: 修复登录bug\"\n  commit --dry-run",
    )
    parser.add_argument("--dry-run", action="store_true", help="预览模式，不提交")
    parser.add_argument("--settings", help="指定 claude settings 文件")
    parser.add_argument("message", nargs="?", default=None, help="提交信息（可省略，自动生成）")
    args = parser.parse_args(argv[1:])

    return run_commit(
        args.message,
        dry_run=args.dry_run,
        settings_file=args.settings,
    )


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
